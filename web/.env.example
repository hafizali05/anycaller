# Copy to .env.local after `sam deploy` and paste the stack outputs.
# These NEXT_PUBLIC_* vars get baked into the browser bundle at build time.

NEXT_PUBLIC_AWS_REGION=eu-west-2

# From CloudFormation stack outputs:
#   sam list stack-outputs --stack-name anycaller --region eu-west-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=
NEXT_PUBLIC_API_BASE_URL=
